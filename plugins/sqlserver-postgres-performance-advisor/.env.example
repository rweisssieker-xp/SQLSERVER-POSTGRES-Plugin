CODEXDB_DEFAULT_ENV=production
CODEXDB_REQUIRE_LIVE_CONNECTION=true
CODEXDB_LIVE_CONNECTION_TIMEOUT_MS=5000
CODEXDB_MIGRATION_SIGNING_KEY=replace-with-hmac-secret

# PostgreSQL / pgvector
CODEXDB_POSTGRES_CONNECTION_STRING=postgres://user:password@localhost:5432/analytics
CODEXDB_PGVECTOR_CONNECTION_STRING=postgres://user:password@localhost:5432/analytics

# SQL Server
CODEXDB_SQLSERVER_SERVER=localhost
CODEXDB_SQLSERVER_USER=sa
CODEXDB_SQLSERVER_PASSWORD=replace-with-password
CODEXDB_SQLSERVER_DATABASE=app_prod
CODEXDB_SQLSERVER_TRUST_SERVER_CERTIFICATE=true

# Observability and graph exports
CODEXDB_PROMETHEUS_URL=http://localhost:9090
CODEXDB_GRAFANA_URL=http://localhost:3000
CODEXDB_GRAFANA_TOKEN=replace-with-token
CODEXDB_NEO4J_URI=bolt://localhost:7687
CODEXDB_NEO4J_USER=neo4j
CODEXDB_NEO4J_PASSWORD=replace-with-password
